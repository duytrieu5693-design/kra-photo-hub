SERVER_PORT=3000
HOST=0.0.0.0

# Storage paths (relative to project root or absolute)
PHOTO_LIBRARY_PATH=./storage/photo_library
EXPORT_PATH=./storage/exports
BATCH_PATH=./storage/batches
DATABASE_PATH=./storage/database/kra-photo-hub.db
LOGS_PATH=./storage/logs
QR_PATH=./storage/qr

# SD card / source folder path (configure this to your SD card mount point)
# Windows examples: D:\DCIM or E:\DCIM
# Mac/Linux examples: /media/sdcard/DCIM or /Volumes/SDCARD/DCIM
SD_CARD_PATH=D:\DCIM

# NAS sync path (optional, leave empty to disable)
NAS_SYNC_PATH=

# Server base URL for generating download links (update to your local IP)
SERVER_BASE_URL=http://localhost:3000
